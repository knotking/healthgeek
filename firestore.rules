rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Profiles can be read and updated by the owner
    match /profiles/{userId} {
      allow read, update: if isOwner(userId);
    }

    // Food logs can be created and read by the owner
    match /food-log/{logId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read: if isOwner(resource.data.userId);
    }

    // Health reports can be created and read by the owner
    match /health-reports/{reportId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read: if isOwner(resource.data.userId);
    }
    
    // Recommendation history can be created and read by the owner
    match /recommendation-history/{historyId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read: if isOwner(resource.data.userId);
    }
  }
}
