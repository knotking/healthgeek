rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to read and write their own food logs
    match /food-log/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Allow users to manage their own health reports
    match /health-reports/{reportId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Allow users to manage their own recommendation history
    match /recommendation-history/{historyId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
