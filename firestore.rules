rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
    match /food-log/{logId} {
      allow read, create: if request.auth.uid == request.resource.data.userId;
    }
    match /health-reports/{reportId} {
      allow read, create: if request.auth.uid == request.resource.data.userId;
    }
    match /recommendation-history/{recId} {
      // Allow owner to do everything
      allow read, write, delete: if resource.data.userId == request.auth.uid;
      
      // Allow public read access to community recommendations
      allow list: if request.query.get('isPublic') == true;
    }
  }
}
