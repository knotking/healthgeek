
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write to their own profile
    match /profiles/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;
    }

    // Users can only read and write to their own health reports
    match /health-reports/{reportId} {
      allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }
    
    // Users can only read and write their own food logs
    match /food-log/{logId} {
        allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }

    // Users can only read and write to their own saved quizzes
    match /saved-quizzes/{quizId} {
        allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }
    
    // Users can only read and write to their own recommendation history
    match /recommendation-history/{recId} {
        allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
        // Allow public reads if isPublic is true
        allow read: if resource.data.isPublic == true;
    }

    // Users can only read and write to their own meditation logs
    match /meditation-log/{logId} {
        allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }

    // Users can only read and write to their own workout logs
    match /workout-log/{logId} {
        allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }
  }
}
