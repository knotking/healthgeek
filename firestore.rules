
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Users can only read/write their own food logs
    match /food-log/{logId} {
      allow read, write, create: if request.auth.uid == request.resource.data.userId;
    }

    // Users can only read/write their own health reports
    match /health-reports/{reportId} {
       allow read, write, create: if request.auth.uid == request.resource.data.userId;
    }
    
    match /recommendation-history/{recommendationId} {
      // Logged-in users can create recommendations for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Users can read, update, or delete their own recommendations
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Allow public read access for community recommendations
      allow list: if request.query.where.isPublic == true;
    }
  }
}
