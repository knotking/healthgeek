
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isPublic() {
      return resource.data.isPublic == true;
    }

    // Profiles: Users can only read/write their own profile.
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Food Log: Users can only read/write their own food logs.
    // Public can count all documents.
    match /food-log/{logId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow list: if request.auth != null;
    }

    // Health Reports: Users can only read/write their own reports.
    // Public can count all documents.
    match /health-reports/{reportId} {
       allow read, create: if isOwner(request.resource.data.userId);
       allow list: if request.auth != null;
    }
    
    // Recommendation History:
    // Users can read/write their own history.
    // Authenticated users can read public recommendations.
    // Public can count all documents.
    match /recommendation-history/{recommendationId} {
        allow read, create, update, delete: if isOwner(request.resource.data.userId);
        allow list: if request.auth != null;
    }
    
    // Allow public counts for the landing page stats
    match /{path=**}/food-log/{logId} {
      allow list: if true;
    }
    match /{path=**}/health-reports/{reportId} {
      allow list: if true;
    }
    match /{path=**}/recommendation-history/{recommendationId} {
      allow list: if true;
    }
  }
}
