
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profile: Users can read and write their own profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Health Reports: Users can read and write their own reports
    match /health-reports/{reportId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Food Log: Users can read and write their own food logs
    match /food-log/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Saved Quizzes: Users can read and write their own quizzes
    match /saved-quizzes/{quizId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Recommendation History: Users can read and write their own history
    match /recommendation-history/{historyId} {
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Meditation Log: Users can read and write their own logs
    match /meditation-log/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

     // Workout Log: Users can read and write their own logs
    match /workout-log/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
