rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Profile: Users can only read and write their own profile.
    match /profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Food Log: Users can only manage their own food logs.
    match /food-log/{logId} {
      allow read, write, delete: if request.auth.uid == resource.data.userId;
    }
    
    // Health Reports: Users can only manage their own health reports.
    match /health-reports/{reportId} {
      allow read, write, delete: if request.auth.uid == resource.data.userId;
      allow list: if true;
    }

    // Recommendation History: Users can manage their own, and read public ones.
    match /recommendation-history/{recId} {
      allow write, delete: if request.auth.uid == request.resource.data.userId;
      allow read: if request.auth.uid == resource.data.userId || resource.data.isPublic == true;
    }
    
    // Saved Quizzes: Users can manage their own quizzes.
    match /saved-quizzes/{quizId} {
        allow read, write, delete: if request.auth.uid == resource.data.userId;
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
