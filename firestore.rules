{
  "rules": {
    "profiles": {
      "$uid": {
        ".read": "request.auth.uid == $uid",
        ".write": "request.auth.uid == $uid"
      }
    },
    "food-log": {
      "$docId": {
        "read": "request.auth.uid == resource.data.userId",
        "write": "request.auth.uid == request.resource.data.userId"
      },
      "allow list": "if request.auth != null && request.query.resource.data.userId == request.auth.uid"
    },
    "health-reports": {
      "$docId": {
        "read": "request.auth.uid == resource.data.userId",
        "write": "request.auth.uid == request.resource.data.userId"
      },
       "allow list": "if request.auth.uid != null && request.query.resource.data.userId == request.auth.uid"
    },
    "recommendation-history": {
       "allow list": "if request.auth.uid != null && (request.query.resource.data.userId == request.auth.uid || request.query.where.isPublic == true)",
       "allow read": "if (request.auth.uid != null && resource.data.isPublic == true) || (request.auth.uid == resource.data.userId)",
       "allow create": "if request.auth.uid == request.resource.data.userId",
       "allow update, delete": "if request.auth.uid == resource.data.userId"
    }
  }
}
