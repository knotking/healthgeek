
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Profiles: Users can read and write to their own profile document
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Food Log: Users can manage their own food logs
    match /food-log/{docId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // Health Reports: Users can manage their own health reports
    match /health-reports/{docId} {
       allow read, write: if isOwner(resource.data.userId);
       allow create: if isOwner(request.resource.data.userId);
    }

    // Saved Quizzes: Users can manage their own saved quizzes
    match /saved-quizzes/{docId} {
       allow read, write: if isOwner(resource.data.userId);
       allow create: if isOwner(request.resource.data.userId);
    }

    // Recommendation History: Users can manage their own recommendation history
    match /recommendation-history/{docId} {
       allow read, write: if isOwner(resource.data.userId);
       allow create: if isOwner(request.resource.data.userId);
    }
    
    // Meditation Log: Users can manage their own meditation logs
    match /meditation-log/{docId} {
       allow read, write: if isOwner(resource.data.userId);
       allow create: if isOwner(request.resource.data.userId);
    }
    
    // Workout Log: Users can manage their own workout logs
    match /workout-log/{docId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
  }
}
