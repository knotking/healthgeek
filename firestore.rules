rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and update their own profile.
    match /profiles/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // Users can create and read their own food logs.
    match /food-log/{logId} {
      allow read, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Users can create and read their own health reports.
    match /health-reports/{reportId} {
        allow read, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
