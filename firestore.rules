rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profiles can only be read or written by the owner
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read/write their own documents in these collections.
    // Unauthenticated users are allowed to count all documents in these collections.
    match /food-log/{document=**} {
      allow list: if true;
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /health-reports/{document=**} {
      allow list: if true;
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /recommendation-history/{document=**} {
      allow list: if true;
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
