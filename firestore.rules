
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Secure the 'profiles' collection
    match /profiles/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Secure the 'health-reports' collection
    match /health-reports/{reportId} {
      allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    // Secure the 'food-log' collection
    match /food-log/{logId} {
      allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    // Secure the 'saved-quizzes' collection
    match /saved-quizzes/{quizId} {
      allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    // Secure the 'recommendation-history' collection
    match /recommendation-history/{recommendationId} {
      allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }
    
    // Secure the 'meditation-log' collection
    match /meditation-log/{logId} {
       allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }
    
    // Secure the 'workout-log' collection
    match /workout-log/{logId} {
       allow read, create, update, delete: if isAuthenticated() && isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }
  }
}
