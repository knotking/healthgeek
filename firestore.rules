
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read-only access to stats for landing page
    match /{path=**}/food-log {
      allow list: if true;
    }
    match /{path=**}/health-reports {
      allow list: if true;
    }
     match /{path=**}/recommendation-history {
      allow list: if true;
    }

    // Protect all other data by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Logged-in users can manage their own profile.
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Logged-in users can manage their own food logs.
    match /food-log/{logId} {
        allow read, write, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Logged-in users can manage their own health reports.
    match /health-reports/{reportId} {
        allow read, write, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Logged-in users can manage their own recommendations.
    match /recommendation-history/{recommendationId} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
