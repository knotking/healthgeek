rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /food-log/{logId} {
      allow read, write: if request.auth.uid == request.resource.data.userId;
    }

    match /health-reports/{reportId} {
      allow read, write: if request.auth.uid == request.resource.data.userId;
    }
    
    match /recommendation-history/{recommendationId} {
      // Allow public read access for documents where isPublic is true
      allow get, list: if resource.data.isPublic == true;

      // Allow authenticated users full access to their own documents
      allow read, write: if request.auth.uid == resource.data.userId;
    }
  }
}
