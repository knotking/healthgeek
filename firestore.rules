rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write to their own profile.
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the food-log collection
    match /food-log/{logId} {
      // Allow create if the user is logged in and the new log belongs to them.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow read if the user is logged in and is requesting their own logs.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Generally, disallow updates and deletes for this app's logic.
      allow update, delete: if false;
    }
  }
}
