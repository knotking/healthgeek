rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to manage their own profiles
    match /profiles/{userId} {
      allow read, create, update, delete: if request.auth.uid == userId;
    }

    // Allow users to manage their own food logs
    match /food-log/{logId} {
      allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }

    // Allow users to manage their own health reports
    match /health-reports/{reportId} {
      allow read, create, update, delete: if request.auth.uid == request.resource.data.userId;
    }

    // Recommendation History Rules
    match /recommendation-history/{docId} {
      // Anyone can read a document if it is marked as public.
      // An authenticated user can read their own documents.
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.userId);

      // An authenticated user can create their own recommendation.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      // An authenticated user can update ONLY the 'isPublic' and 'rating' fields of their own document.
      allow update: if request.auth != null 
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic', 'rating']);

      // An authenticated user can delete their own documents.
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
