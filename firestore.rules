
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: Users can read and write to their own profile.
    match /profiles/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Food Log: Users can create, read, update, and delete their own food logs.
    // They can only query logs that belong to them.
    match /food-log/{logId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Health Reports: Users can create, read, update, and delete their own health reports.
    // They can only query reports that belong to them.
    match /health-reports/{reportId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
