rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /food-log/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /health-reports/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /recommendation-history/{recommendationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /recommendation-history/{recommendationId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/recommendation-history/$(recommendationId)).data.isPublic == true;
    }
  }
}
